{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Server (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Live Server (live-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", ".", "--port=5500", "--no-browser"],
      "port": 5500
    }
  ]
}
